# Required for the terminal's `ask <question>` AI mode.
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Defaults to gemini-flash-lite-latest (fastest, thinking disabled
# for low-latency terminal responses).
GEMINI_MODEL=gemini-flash-lite-latest

# Optional. Canonical site URL used for the sitemap, RSS feed, canonical tags,
# and JSON-LD. Falls back to `siteUrl` in content/profile.json if unset.
# Useful for pointing preview deployments at the right host.
NEXT_PUBLIC_SITE_URL=https://robinsingh.dev
